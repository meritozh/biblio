    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.8.3",
